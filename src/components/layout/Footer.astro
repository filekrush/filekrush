---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--bg)]">
  <div class="max-w-[990px] mx-auto px-6 py-10 border-t border-[#e0e0e0]">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-[14px]" style="color: var(--text-secondary);">
        &copy; {currentYear} Filekrush. All files processed in your browser. Nothing is uploaded.
      </p>
      <div class="flex gap-6 text-[14px]" style="color: var(--text-secondary);">
        <a href="/privacy" class="hover:text-[var(--text-primary)] transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-[var(--text-primary)] transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
