---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  { title: 'Compress Image', desc: 'Reduce image size to exact KB', href: '/compress', icon: '🗜️' },
  { title: 'Resize Image', desc: 'Resize to exact dimensions', href: '/resize', icon: '📐' },
  { title: 'Convert Format', desc: 'JPG, PNG, WebP conversion', href: '/convert', icon: '🔄' },
  { title: 'Passport Photo', desc: 'Country-specific photo maker', href: '/passport-photo', icon: '📷' },
  { title: 'Image to PDF', desc: 'Convert images to PDF', href: '/image-to-pdf', icon: '📄' },
  { title: 'Metadata Tool', desc: 'View or remove EXIF data', href: '/metadata', icon: '🔒' },
];
---

<BaseLayout
  title="Filekrush — Free Browser-Based File Tools"
  description="Compress, resize, convert images and more. Everything runs in your browser. No upload, no signup, no limits."
  canonical="/"
>
  <!-- Hero -->
  <section class="py-16 sm:py-24 text-center px-4">
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">
      File tools that run in your browser.
    </h1>
    <p class="text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto mb-2">
      Compress, resize, convert. No uploads. No signups. Instant results.
    </p>
    <p class="text-sm text-gray-400">
      Your files never leave your device.
    </p>
  </section>

  <!-- Tool Grid -->
  <section class="max-w-4xl mx-auto px-4 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="group block p-6 rounded-2xl border border-gray-200 hover:border-[var(--brand-primary)] hover:shadow-md transition-all"
        >
          <div class="text-3xl mb-3">{tool.icon}</div>
          <h2 class="text-lg font-semibold text-gray-900 group-hover:text-[var(--brand-primary)] transition-colors">
            {tool.title}
          </h2>
          <p class="text-sm text-gray-500 mt-1">{tool.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
