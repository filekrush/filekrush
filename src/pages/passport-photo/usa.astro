---
import ToolLayout from '../../layouts/ToolLayout.astro';
import PassportPhoto from '../../components/tools/PassportPhoto';
---

<ToolLayout
  title="US Passport Photo Size — 2x2 Inches, 600x600px | Filekrush"
  description="Create US passport photos (2x2 inches, 600x600px) instantly. White background, correct dimensions. Free, no upload."
  canonical="/passport-photo/usa"
  heading="US Passport Photo"
  subheading="2 × 2 inches (600 × 600px) — white background, ready to submit."
>
  <PassportPhoto client:only="react" defaultCountry="usa" />

  <Fragment slot="content">
    <section class="prose prose-gray max-w-none">
      <h2>US passport photo requirements</h2>
      <p>The US Department of State requires passport photos measuring 2 × 2 inches (51 × 51mm) at 600 × 600 pixels minimum. The background must be white, and the head height should be between 25-35mm from chin to crown.</p>

      <h2>Where is this size used?</h2>
      <p>US passport applications, US visa applications, Green Card (permanent residency) applications, and various USCIS immigration forms.</p>
    </section>
  </Fragment>
</ToolLayout>
