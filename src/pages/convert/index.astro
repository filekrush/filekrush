---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ConvertFormat from '../../components/tools/ConvertFormat';
---

<ToolLayout
  title="Convert Image Format Free Online — JPG, PNG, WebP | Filekrush"
  description="Convert images between JPG, PNG, and WebP. Runs in your browser — no upload, no signup."
  canonical="/convert"
  heading="Convert Image Format"
  subheading="Switch between JPG, PNG, and WebP — free, private, instant."
>
  <ConvertFormat client:only="react" fromFormat="" />

  <Fragment slot="content">
    <section class="prose prose-gray max-w-none">
      <h2>How it works</h2>
      <ol>
        <li><strong>Drop your image</strong> — supports JPG, PNG, and WebP.</li>
        <li><strong>Pick a format</strong> — choose your output format and quality level.</li>
        <li><strong>Download</strong> — your converted image is ready instantly.</li>
      </ol>

      <h2>When to use which format?</h2>
      <p><strong>JPG</strong> — best for photographs. Small file size, no transparency. Use for photos, social media, email.</p>
      <p><strong>PNG</strong> — best for graphics with transparency. Larger files but lossless quality. Use for logos, screenshots, graphics.</p>
      <p><strong>WebP</strong> — best for web. Smaller than both JPG and PNG at similar quality. Supported by all modern browsers.</p>
      <p><strong>HEIC</strong> — default iPhone photo format. Great quality but not widely supported outside Apple devices. Convert to JPG or PNG for universal compatibility.</p>
    </section>
  </Fragment>
</ToolLayout>