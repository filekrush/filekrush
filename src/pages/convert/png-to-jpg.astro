---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ConvertFormat from '../../components/tools/ConvertFormat';
---

<ToolLayout
  title="Convert PNG to JPG Free Online | Filekrush"
  description="Convert PNG images to JPG format instantly. Runs in your browser — no upload, no signup."
  canonical="/convert/png-to-jpg"
  heading="Convert PNG to JPG"
  subheading="Convert your PNG to JPG format — free, private, instant."
>
  <ConvertFormat client:only="react" fromFormat="image/png" toFormat="image/jpeg" />

  <Fragment slot="content">
    <section class="prose prose-gray max-w-none">
      <h2>Why convert PNG to JPG?</h2>
      <p>PNG files are often 5-10x larger than JPGs for photographs. Converting to JPG dramatically reduces file size, making images easier to email, upload to forms, and use on websites. Note that JPG does not support transparency — transparent areas will become white.</p>
    </section>
  </Fragment>
</ToolLayout>
